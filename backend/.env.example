# ─── Base de données (Supabase PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres.XXXX:PASSWORD@aws-0-eu-west-3.pooler.supabase.com:6543/postgres

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Supabase (optionnel — pour storage fichiers) ────────────────────────────
SUPABASE_URL=https://XXXX.supabase.co
SUPABASE_KEY=eyJ...

# ─── App ──────────────────────────────────────────────────────────────────────
DEBUG=false
ALLOWED_ORIGINS=["http://localhost:3000","https://votre-domaine.com"]
STORAGE_BACKEND=local
STORAGE_PATH=./uploads
MAX_FILE_SIZE_MB=50
